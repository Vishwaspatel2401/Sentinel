# =============================================================================
# .gitignore for Sentinel
# Rule of thumb: commit SOURCE, ignore GENERATED and SECRET files.
# =============================================================================

# ── Secrets ───────────────────────────────────────────────────────────────────
# Never commit API keys or database credentials.
# Anyone who clones the repo creates their own .env from .env.example
.env
.env.local
.env.staging
.env.production
# Allow .env.example — that's the template, it has no real secrets
!.env.example

# Never commit certificates or private keys
*.pem
*.key
*.crt
*.p12

# ── RAG index files ───────────────────────────────────────────────────────────
# These are generated by running: python3 scripts/build_index.py
# They are large binary files that change every time you add a runbook.
# Commit the .md runbooks in data/runbooks/ — not the index files.
data/runbooks.index
data/chunks.json
data/bm25.pkl

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]                  # .pyc, .pyo, .pyd compiled bytecode
*.pyo
.Python

# Virtual environments — each developer creates their own
venv/
backend/venv/
env/
.venv/

# Python packaging artifacts — created by pip install -e . or python setup.py
*.egg-info/
dist/
build/
*.egg

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml               # XML report used by coverage badge tools
htmlcov/                   # coverage HTML report

# ── Type checkers and linters ─────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Alembic ───────────────────────────────────────────────────────────────────
# The versions/ folder IS committed — those are your migration history.
# Only ignore the compiled cache files inside it.
backend/alembic/__pycache__/
backend/alembic/versions/__pycache__/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── Docker ────────────────────────────────────────────────────────────────────
# Postgres data volume if accidentally created as a local directory
postgres_data/

# ── Frontend (future) ─────────────────────────────────────────────────────────
# Node packages and build output — if a frontend is added later
node_modules/
frontend/dist/
frontend/build/
frontend/.next/
frontend/.nuxt/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
pip-log.txt

# Production secrets — never commit
.env.production
.env.*.local
nginx/certs/
*.pem
*.key
